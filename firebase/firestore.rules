rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow public read access to mmi_readings and mmi_meta collections
    match /mmi_readings/{documentId} {
      allow read: if true;
      allow create, update, delete: if false;  // Only Admin SDK can write
    }
    
    match /mmi_meta/{documentId} {
      allow read: if true;
      allow create, update, delete: if false;  // Only Admin SDK can write
    }
    
    // Deny access to all other collections by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}